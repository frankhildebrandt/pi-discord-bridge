    "allowedAttachmentMimeTypes": [
      "text/plain",
      "text/markdown",
      "text/csv",
      "application/json",
      "application/xml",
      "text/xml",
      "text/yaml",
      "application/yaml",
      "application/x-yaml",
      "application/javascript",
      "text/javascript",
      "text/css",
      "text/html",
      "image/png",
      "image/jpeg",
      "image/webp",
      "image/gif"
    ]
  }
